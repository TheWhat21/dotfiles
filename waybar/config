{
	/* "mode": "dock", */
	"layer": "top",
	"spacing": 0,
	"height": 0,
	"margin-top": 0,
	"margin-bottom": 0,
	"position": "top",
	/* "margin-left": 45,
	"margin-right": 45, */

	"modules-left": ["hyprland/workspaces"],
	"modules-center": ["hyprland/window"],
	"modules-right": ["group/group-right"],

	"custom/power": {
	    "format" : "⏻ ",
	        "tooltip": false,
	        "menu": "on-click",
	        "menu-file": "~/.config/waybar/power_menu.xml",
	        "menu-actions": {
	            "shutdown": "shutdown",
	            "reboot": "reboot",
	            "suspend": "systemctl suspend",
	            "hibernate": "systemctl hibernate",
	        },
	},

	"hyprland/workspaces": {
		"format": "{name} {icon}",
		"format-icons": {
			"urgent": "",
			"default": "",
			"active": "",
		},
		"hide-empty": true
	},

	"hyprland/window": {
		"max-length": 75,
		// "rewrite": {
		// 	"(.*) - peaclock": "󰺗",
		// 	"class<pcmanfm>": "󰉓",
		// 	"Yazi: (.*)": "󰉓",
		// 	"(.*) - micro": "μ",
		// 	"(.*) — LibreWolf": "",
		//     "(.*) — Mozilla Firefox": "",
		//     "(.*) - fish": "",
		//     "kitty": "󰄛"
		// },
	},

	"group/group-right": {
		"orientation": "inherit",
		"modules": ["network", "upower", "wireplumber", "tray", "clock"]
	},

	"network": {
		"format-wifi": "  {bandwidthDownBits}",
		"format-ethernet": "󰈁 {bandwidthDownBits}",
		"format-disconnected": "󰣽  No Network",
		"interval": 5
	},

	"upower": {
		"format": " {percentage}",
		"tooltip": false
	},

	"wireplumber": {
		"format": "  {volume}%",
		"format-muted": "󰝟 ",
		"on-click": "toggle_fuzzel_sound"
	},

	"tray": {
		"spacing": 10
	},

	"clock": {
		"interval": 60,
		"format": "  {:%H:%M}",
		"max-length": 25,
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"format": {
				"today": "<span color='#88c0d0'><b><u>{}</u></b></span>" /* nord8 */
			}
		}
	}
}
